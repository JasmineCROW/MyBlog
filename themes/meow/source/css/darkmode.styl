@import '_style/_default/global-settings'

body.dm-dark
  --color-bg: #0b0b0d
  --color-surface: #141416
  --color-surface-dark: #18181b
  --color-text: #f5f5f5
  --color-text-muted: #a1a1aa
  --color-border: rgba(255, 255, 255, 0.08)
  --color-link: #e5e5e5
  --color-link-hover: #ffffff
  --color-card-bg: #18181b
  --color-card-text: #f5f5f5
  --color-card-muted: #a1a1aa
  --color-accent-subtle: #222222
  --color-quote-bg: #1f1f23
  --color-quote-border: #888888
  background: #0b0b0d
  color: #e7e7e5

  header
    background: rgba(20, 20, 20, 0.94)
    border-color: #3b3b3b

  .nav-info #nav-title,
  .top-menu-expanded .top-menu-item,
  #theme-mode-switch
    color: #ededeb

  .top-menu-expanded .top-menu-item,
  #theme-mode-switch,
  .top-search #top-search-btn
    border-color: #5a5a5a
    background: #1b1b1b

  .top-menu-expanded .top-menu-item:hover,
  #theme-mode-switch:hover
    color: #ffffff
    background: #eeeeeb
    border-color: #eeeeeb

  .top-search #top-search-btn span
    color: #c7c7c4

  .blog-info
    border-color: #3b3b3b
    background: #141416
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.28)

  .blog-title
    color: #f0f0ee

  .main-content
    border-color: #393939
    background: #141416
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.32)

  a,
  .post-title-index h1 a,
  .category-list-link,
  .article-item a
    color: #f5f5f5

    &:hover
      color: #ffffff

  h1,h2,h3,h4,h5,h6
    color: #f0f0ee

  .index-posts .index-post-item
    border-color: #3b3b3b
    background: #18181b
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.28)

    &:hover
      border-color: #747474
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.38)

    .post-top
      border-color: #d8d8d5
      background: #18181b
      color: #e9e9e6

    .read-more
      background: #f0f0ee

      i, .read-more-link
        color: #181818

      &:hover
        background: #181818
        border: 1px solid #d8d8d5

        i, .read-more-link
          color: #f0f0ee

  .post-head-info,
  .post-published-at,
  .post-categories .post-category,
  .post-tags .post-tag,
  .category-list-count,
  .footer-content
    color: #a9a9a7

  .category-tree-row:hover
    background: #272727
    border-color: #4b4b4b

  .category-tree-icon,
  .category-tree-toggle
    color: #bdbdbd

  .category-list-count
    border-color: #4b4b4b
    background: #292929

  #top-menu-hidden,
  #top-menu-hidden .menu-hidden-content
    background: rgba(20, 20, 20, 0.96)

  #top-menu-hidden .menu-hidden-item
    border-color: #505050
    background: #202020
    color: #e7e7e5

    &:hover
      background: #eeeeeb
      color: #171717

  .search-container,
  .reward-container
    border-color: #444444
    background: #202020

  .search-head,
  #search-result em
    color: #f5f5f5

  #search-input
    border-color: #555555
    background: #171717
    color: #efefed

  #tool-bar-main
    border-color: #444444
    background: #242424
    color: #c7c7c7

    div
      color: #c7c7c7

    div:hover
      background: #333333
      color: #f5f5f5

  code,
  figure.highlight,
  details summary,
  details[open]
    background: #2a2a2a
    color: #ececea

  thead
    background: #363636
    color: #f4f4f2

  *::-webkit-scrollbar-thumb
    background-color: #4b4b4b

  *::-webkit-scrollbar-track
    background-color: #191919

  .post-title h1,
  .page-title,
  .archives-year-link,
  .archives-month-link
    color: #f5f5f5

  .post-info,
  .post-head-info,
  .post-categories .post-category,
  .post-tags .post-tag
    color: #a1a1aa

  blockquote
    background: #1f1f23
    border-left-color: #888888
    color: #eeeeee

  .tag-cloud .tag-cloud-link
    color: var(--tag-dark-color, #d4d4d4)

    &:hover
      color: #f2b8b8

  .tag-list-container a
    color: #d4d4d4

    &:hover
      color: #f2b8b8

  .article-item
    border-color: rgba(255, 255, 255, 0.08)
    background: #18181b

  .article-item-title
    color: #f5f5f5

  .article-item-preview,
  .article-item-date
    color: #a1a1aa

  .home-page
    --crow-red: #b45353
    --crow-red-soft: #f2b8b8
    --paper-warm: #151515
    --ink-black: #f5f5f5
    --ink-muted: #a1a1aa
    --line-soft: rgba(255, 255, 255, 0.1)
    color: #f5f5f5

  .home-background:after
    background:
      linear-gradient(90deg, rgba(10, 10, 12, 0.82) 0%, rgba(10, 10, 12, 0.62) 42%, rgba(10, 10, 12, 0.22) 72%, rgba(10, 10, 12, 0.08) 100%),
      rgba(0, 0, 0, 0.2)

  .home-main .home-main-content
    background: transparent
    box-shadow: none

  .home-hero
    background:
      radial-gradient(circle at 18% 42%, rgba(255, 255, 255, 0.08), transparent 34%),
      linear-gradient(180deg, rgba(10, 10, 12, 0.16), rgba(10, 10, 12, 0.08))
    box-shadow: none

    &:before
      background: linear-gradient(180deg, rgba(0, 0, 0, 0.12), transparent 56%)

    &:after
      background: linear-gradient(180deg, transparent, rgba(11, 11, 13, 0.5))

  .home-content-surface
    border-top-color: rgba(255, 255, 255, 0.12)
    background: rgba(11, 11, 13, 0.9)

  .home-paged-feed
    border-color: rgba(255, 255, 255, 0.12)
    background: rgba(11, 11, 13, 0.9)

  @supports ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px)))
    .home-content-surface
      background: rgba(11, 11, 13, 0.68)

    .home-paged-feed
      background: rgba(11, 11, 13, 0.68)

  .home-kicker,
  .home-side-heading,
  .home-section-heading p
    color: #f2b8b8

  .home-typewriter,
  .home-subtitle,
  .home-section-heading h2,
  .home-side-heading h2
    color: #f5f5f5

  .home-description
    color: #a1a1aa

  .home-start-button
    border-color: #f5f5f5
    background: #f5f5f5
    color: #111111

    &:hover
      border-color: #b45353
      background: #b45353
      color: #ffffff

  .home-side-card
    border-color: rgba(255, 255, 255, 0.1)
    background: rgba(24, 24, 27, 0.82)
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.24)

  .home-empty-state
    border-color: rgba(255, 255, 255, 0.1)
    background: rgba(24, 24, 27, 0.82)
    color: #a1a1aa

  .home-category-item
    border-color: rgba(255, 255, 255, 0.08)
    background: rgba(39, 39, 42, 0.62)

    summary
      color: #e5e5e5

      &:after
        color: #a1a1aa

      &:hover
        color: #f2b8b8

    &[open] summary
      background: rgba(180, 83, 83, 0.12)

  .home-category-count,
  .home-archive-item span:last-child
    background: #27272a
    color: #d4d4d8

  .home-category-link
    color: #f2b8b8

    &:hover
      color: #ffffff

  .home-archive-item
    border-bottom-color: rgba(255, 255, 255, 0.08)
    color: #e5e5e5

    &:hover
      color: #f2b8b8

  .home-tag-cloud .tag-cloud-link:hover
    color: #f2b8b8

  @media screen and (max-width: 768px)
    .home-hero
      background:
        linear-gradient(180deg, rgba(10, 10, 12, 0.46) 0%, rgba(10, 10, 12, 0.28) 48%, rgba(10, 10, 12, 0.08) 100%)
