@import '_style/_default/global-settings'

body.dm-dark
  --color-bg: #0b0b0d
  --color-surface: #141416
  --color-surface-dark: #18181b
  --color-text: #f5f5f5
  --color-text-muted: #a1a1aa
  --color-border: rgba(255, 255, 255, 0.08)
  --color-link: #e5e5e5
  --color-link-hover: #ffffff
  --color-card-bg: #18181b
  --color-card-text: #f5f5f5
  --color-card-muted: #a1a1aa
  --color-accent-subtle: #222222
  --color-quote-bg: #1f1f23
  --color-quote-border: #888888
  background: #0b0b0d
  color: #e7e7e5

  header
    background: rgba(20, 20, 20, 0.94)
    border-color: #3b3b3b

  .nav-info #nav-title,
  .top-menu-expanded .top-menu-item,
  #theme-mode-switch
    color: #ededeb

  .top-menu-expanded .top-menu-item,
  #theme-mode-switch,
  .top-search #top-search-btn
    border-color: #5a5a5a
    background: #1b1b1b

  .top-menu-expanded .top-menu-item:hover,
  #theme-mode-switch:hover
    color: #ffffff
    background: #eeeeeb
    border-color: #eeeeeb

  .top-search #top-search-btn span
    color: #c7c7c4

  .blog-info
    border-color: #3b3b3b
    background: #141416
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.28)

  .blog-title
    color: #f0f0ee

  .main-content
    border-color: #393939
    background: #141416
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.32)

  a,
  .post-title-index h1 a,
  .category-list-link,
  .article-item a
    color: #f5f5f5

    &:hover
      color: #ffffff

  h1,h2,h3,h4,h5,h6
    color: #f0f0ee

  .index-posts .index-post-item
    border-color: #3b3b3b
    background: #18181b
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.28)

    &:hover
      border-color: #747474
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.38)

    .post-top
      border-color: #d8d8d5
      background: #18181b
      color: #e9e9e6

    .read-more
      background: #f0f0ee

      i, .read-more-link
        color: #181818

      &:hover
        background: #181818
        border: 1px solid #d8d8d5

        i, .read-more-link
          color: #f0f0ee

  .post-head-info,
  .post-published-at,
  .post-categories .post-category,
  .post-tags .post-tag,
  .category-list-count,
  .footer-content
    color: #a9a9a7

  .category-tree-row:hover
    background: #272727
    border-color: #4b4b4b

  .category-tree-icon,
  .category-tree-toggle
    color: #bdbdbd

  .category-list-count
    border-color: #4b4b4b
    background: #292929

  #top-menu-hidden,
  #top-menu-hidden .menu-hidden-content
    background: rgba(20, 20, 20, 0.96)

  #top-menu-hidden .menu-hidden-item
    border-color: #505050
    background: #202020
    color: #e7e7e5

    &:hover
      background: #eeeeeb
      color: #171717

  .search-container,
  .reward-container
    border-color: #444444
    background: #202020

  .search-head,
  #search-result em
    color: #f5f5f5

  #search-input
    border-color: #555555
    background: #171717
    color: #efefed

  #tool-bar-main, #font-size-controls
    border-color: #444444
    background: #242424

    div
      color: #c7c7c7

    div:hover
      color: #f5f5f5

  code,
  figure.highlight,
  details summary,
  details[open]
    background: #2a2a2a
    color: #ececea

  thead
    background: #363636
    color: #f4f4f2

  *::-webkit-scrollbar-thumb
    background-color: #4b4b4b

  *::-webkit-scrollbar-track
    background-color: #191919

  .post-title h1,
  .page-title,
  .archives-year-link,
  .archives-month-link
    color: #f5f5f5

  .post-info,
  .post-head-info,
  .post-categories .post-category,
  .post-tags .post-tag
    color: #a1a1aa

  blockquote
    background: #1f1f23
    border-left-color: #888888
    color: #eeeeee

  .tag-cloud .tag-cloud-link
    color: var(--tag-dark-color, #d4d4d4)

    &:hover
      color: #f5f5f5

  .tag-list-container a
    color: #d4d4d4

    &:hover
      color: #f5f5f5

  .article-item
    border-color: rgba(255, 255, 255, 0.08)
    background: #18181b

  .article-item-title
    color: #f5f5f5

  .article-item-preview,
  .article-item-date
    color: #a1a1aa
