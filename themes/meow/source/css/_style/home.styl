body .main.home-main
  max-width: none
  width: 100%

  .main-content.home-main-content
    margin: 0 auto 58px
    padding: 0
    border: 0
    border-radius: 0
    background: transparent
    box-shadow: none

.home-page
  --content-padding: clamp(24px, 3vw, 36px)
  --content-gap: 32px
  --content-max-width: 1180px
  --header-offset: 58px
  --crow-red: #7f1d1d
  --crow-red-soft: #991b1b
  --paper-warm: #f7f3ea
  --ink-black: #111111
  --ink-muted: #66615a
  --line-soft: #ded8ce
  color: var(--ink-black)

  *,
  *:before,
  *:after
    box-sizing: border-box

.home-hero
  position: relative
  display: grid
  grid-template-columns: minmax(0, 1.2fr) minmax(220px, 0.8fr)
  align-items: center
  gap: clamp(28px, 6vw, 78px)
  min-height: calc(100svh - var(--header-offset))
  width: 100%
  padding-block: clamp(72px, 10vh, 118px)
  padding-left: unquote('max(var(--content-padding), calc((100vw - var(--content-max-width)) / 2 + var(--content-padding)))')
  padding-right: unquote('max(var(--content-padding), calc((100vw - var(--content-max-width)) / 2 + var(--content-padding)))')
  border: 0
  border-radius: 0
  background:
    radial-gradient(circle at 76% 42%, rgba(127, 29, 29, 0.06), transparent 30%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.72), rgba(247, 243, 234, 0.98) 58%, rgba(240, 235, 226, 0.88)),
    repeating-linear-gradient(90deg, rgba(17, 17, 17, 0.018) 0, rgba(17, 17, 17, 0.018) 1px, transparent 1px, transparent 14px)
  box-shadow: none
  overflow: hidden

  &:before
    content: ''
    position: absolute
    inset: 0
    pointer-events: none
    background:
      linear-gradient(115deg, transparent 0 58%, rgba(127, 29, 29, 0.1) 58.08%, transparent 58.4%),
      linear-gradient(160deg, transparent 0 70%, rgba(17, 17, 17, 0.05) 70.08%, transparent 70.35%)
    opacity: 0.72

  &:after
    content: ''
    position: absolute
    left: unquote('max(var(--content-padding), calc((100vw - var(--content-max-width)) / 2 + var(--content-padding)))')
    right: unquote('max(var(--content-padding), calc((100vw - var(--content-max-width)) / 2 + var(--content-padding)))')
    bottom: 30px
    height: 1px
    background: linear-gradient(90deg, rgba(127, 29, 29, 0.42), rgba(17, 17, 17, 0.12), transparent)
    pointer-events: none

.home-kicker
  margin: 0 0 12px
  color: var(--crow-red)
  font-size: 0.78rem
  font-weight: 800
  letter-spacing: 0.08em
  text-transform: uppercase

.home-hero-copy
  position: relative
  z-index: 1

  h1
    margin: 0
    max-width: 620px
    color: #101010
    font-size: clamp(3.2rem, 8vw, 7.4rem)
    line-height: 0.95
    font-weight: 900

.home-subtitle
  margin: 28px 0 0
  color: #191919
  font-size: clamp(1.16rem, 2vw, 1.5rem)
  font-weight: 700

.home-description
  margin: 12px 0 34px
  color: var(--ink-muted)
  font-size: 1rem
  line-height: 1.8

.home-start-button
  display: inline-flex
  align-items: center
  justify-content: center
  min-height: 42px
  padding: 0 20px
  border: 1px solid #111111
  border-radius: 999px
  background: #111111
  color: #ffffff
  text-decoration: none
  font-size: 0.95rem
  font-weight: 800
  transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease, color 180ms ease

  &:hover
    border-color: var(--crow-red)
    background: var(--crow-red)
    color: #ffffff
    transform: translateY(-2px)

.home-hero-mark
  position: relative
  display: flex
  align-items: center
  justify-content: center
  min-height: 380px
  z-index: 1

  img
    position: relative
    z-index: 2
    width: min(78%, 360px)
    height: auto
    filter: grayscale(1) contrast(1.08)
    opacity: 0.9

  &:before
    content: ''
    position: absolute
    width: min(86%, 420px)
    aspect-ratio: 1
    border: 1px solid rgba(127, 29, 29, 0.16)
    border-radius: 50%
    background: radial-gradient(circle, rgba(255, 255, 255, 0.48), transparent 62%)

  &:after
    content: ''
    position: absolute
    right: 4%
    bottom: 18%
    width: 140px
    height: 2px
    background: var(--crow-red)
    transform: rotate(-18deg)
    opacity: 0.56

.home-hero-feather
  position: absolute
  right: 15%
  bottom: 22%
  width: 124px
  height: 34px
  border-bottom: 1px solid rgba(127, 29, 29, 0.38)
  border-radius: 50%
  transform: rotate(-18deg)
  z-index: 1

.home-grid
  display: grid
  grid-template-columns: minmax(0, 1fr) minmax(260px, 0.36fr)
  gap: var(--content-gap)
  align-items: start
  max-width: var(--content-max-width)
  width: unquote('min(94%, var(--content-max-width))')
  margin: 58px auto 0

.home-feed
  padding-inline: var(--content-padding)
  min-width: 0

.home-section-heading
  display: flex
  align-items: end
  justify-content: space-between
  gap: 18px
  margin: 0 0 16px
  padding: 0 0 12px
  border-bottom: 1px solid var(--line-soft)
  scroll-margin-top: calc(var(--header-offset) + 24px)

  p
    margin: 0
    color: var(--crow-red)
    font-size: 0.78rem
    font-weight: 800
    letter-spacing: 0.08em
    text-transform: uppercase

  h2
    margin: 0
    color: #111111
    font-size: 1.12rem
    font-weight: 800

.home-sidebar
  position: static
  display: flex
  flex-direction: column
  gap: 18px
  padding-inline: var(--content-padding)

.home-latest-heading
  margin-top: 28px

.home-paged-feed
  width: min(92%, 900px)
  margin: 34px auto 0
  padding-inline: var(--content-padding)

  .index-posts
    width: 100%

.home-empty-state
  padding: 28px 30px
  border: 1px solid var(--line-soft)
  border-radius: 18px
  background: rgba(255, 255, 255, 0.54)
  color: var(--ink-muted)
  text-align: center

  p
    margin: 0

.home-side-card
  padding: var(--content-padding)
  border: 1px solid var(--line-soft)
  border-radius: 18px
  background: rgba(255, 255, 255, 0.62)
  box-shadow: 0 12px 30px rgba(30, 24, 18, 0.05)

.home-side-heading
  display: flex
  align-items: center
  gap: 9px
  margin-bottom: 14px
  color: var(--crow-red)

  h2
    margin: 0
    color: #151515
    font-size: 1.02rem
    font-weight: 900

.home-category-list,
.home-archive-list
  display: flex
  flex-direction: column
  gap: 8px

.home-category-item
  border: 1px solid #e6dfd5
  border-radius: 12px
  background: rgba(247, 243, 234, 0.55)
  overflow: hidden

  summary
    display: flex
    align-items: center
    justify-content: space-between
    gap: 12px
    padding: 10px 12px
    cursor: pointer
    list-style: none
    color: #202020
    transition: color 180ms ease, background-color 180ms ease

    &::-webkit-details-marker
      display: none

    &:after
      content: '+'
      color: #8a8580
      font-weight: 800
      transition: transform 200ms ease, color 180ms ease

    &:hover
      color: var(--crow-red)

  &[open] summary
    background: rgba(127, 29, 29, 0.06)

    &:after
      color: var(--crow-red)
      transform: rotate(45deg)

.home-category-name
  min-width: 0
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  font-weight: 800

.home-category-count,
.home-archive-item span:last-child
  display: inline-flex
  align-items: center
  justify-content: center
  min-width: 24px
  padding: 2px 7px
  border-radius: 999px
  background: #eee8df
  color: #5d5751
  font-size: 0.75rem
  font-weight: 800

.home-category-link
  display: block
  max-height: 0
  padding: 0 12px
  color: var(--crow-red)
  text-decoration: none
  font-size: 0.86rem
  overflow: hidden
  transition: max-height 220ms ease, padding 220ms ease, color 180ms ease

  &:hover
    color: #111111

.home-category-item[open] .home-category-link
  max-height: 42px
  padding: 0 12px 11px

.home-tag-cloud
  justify-content: flex-start
  margin: 0
  gap: 8px 14px

  .tag-cloud-link:hover
    color: var(--crow-red)
    transform: translateY(-1px) scale(1.04)

.home-archive-item
  display: flex
  align-items: center
  justify-content: space-between
  gap: 12px
  padding: 9px 0
  border-bottom: 1px solid rgba(222, 216, 206, 0.82)
  color: #252525
  text-decoration: none
  transition: color 180ms ease, padding-left 180ms ease

  &:last-child
    border-bottom: 0

  &:hover
    color: var(--crow-red)
    padding-left: 4px

.home-page .reveal-item,
.home-page .index-post-item
  opacity: 0
  transform: translateY(14px)
  transition: opacity 520ms ease var(--reveal-delay, 0ms), transform 520ms ease var(--reveal-delay, 0ms)

.home-page .reveal-item.is-visible,
.home-page .index-post-item.is-visible
  opacity: 1
  transform: translateY(0)

@media screen and (max-width: 900px)
  .home-grid
    grid-template-columns: 1fr

  .home-sidebar
    display: grid
    grid-template-columns: repeat(3, minmax(0, 1fr))
    padding-inline: var(--content-padding)

@media screen and (max-width: 768px)
  .home-page
    --content-padding: 18px
    --content-gap: 22px

  body .main.home-main
    width: 100%

    .main-content.home-main-content
      margin-top: 18px

  .home-hero
    grid-template-columns: 1fr
    gap: 24px
    min-height: calc(100svh - var(--header-offset))
    padding-block: 54px 44px
    padding-left: var(--content-padding)
    padding-right: var(--content-padding)

  .home-hero-mark
    min-height: 210px
    order: 2

    img
      width: min(54%, 190px)

    &:before
      width: 190px
      height: 190px

  .home-hero-copy h1
    font-size: clamp(2.35rem, 14vw, 3.8rem)

  .home-grid
    gap: var(--content-gap)
    margin-top: 24px

  .home-sidebar
    grid-template-columns: 1fr

  .home-side-card
    border-radius: 16px

@media (prefers-reduced-motion: reduce)
  .home-start-button,
  .home-category-item summary,
  .home-category-link,
  .home-archive-item,
  .home-page .reveal-item,
  .home-page .index-post-item
    transition: none

  .home-page .reveal-item,
  .home-page .index-post-item
    opacity: 1
    transform: none
