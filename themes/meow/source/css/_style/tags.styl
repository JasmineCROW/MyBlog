.tag-cloud
  margin: 24px auto
  display: flex
  justify-content: center
  flex-flow: row wrap
  align-items: baseline
  gap: 10px 18px

  .tag-cloud-link
    margin: 0
    padding: 2px 3px
    border: 0
    border-radius: 6px
    color: var(--tag-light-color, #555555)
    font-size: var(--tag-size, 1rem)
    line-height: 1.35
    text-decoration: none
    transition: color 160ms ease, transform 160ms ease

    &:hover
      color: #7f1d1d
      transform: translateY(-1px) scale(1.04)

.tag-list-container
  margin: 18px auto
  display: flex
  flex-flow: row wrap
  // justify-content: center
  align-items: baseline
  font-size: article-title4-font-size
  color: #555555

  a
    margin: 5px 7px
    padding: 2px 3px
    border: 0
    border-radius: 6px
    color: #555555

    &:hover
      color: #7f1d1d

.tag-count
  vertical-align: super
  font-size: superscript-font-size
  margin-left: 3px
  opacity: 0.72
