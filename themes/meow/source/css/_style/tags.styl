.tag-cloud
  margin: 20px auto
  display: flex
  justify-content: center
  flex-flow: row wrap
  align-items: baseline

  a
    margin: 5px 7px
    padding: 4px 10px
    border: 1px solid #d0d0d0
    border-radius: 999px
    color: #555555
    text-decoration: none

    &:hover
      background: #111111
      border-color: #111111
      color: #ffffff

.tag-list-container
  margin: 18px auto
  display: flex
  flex-flow: row wrap
  // justify-content: center
  align-items: baseline
  font-size: article-title4-font-size
  color: #555555

  a
    margin: 5px 7px
    padding: 4px 10px
    border: 1px solid #d0d0d0
    border-radius: 999px
    color: #555555

    &:hover
      background: #111111
      border-color: #111111
      color: #ffffff

.tag-count
  vertical-align: super
  font-size: superscript-font-size
