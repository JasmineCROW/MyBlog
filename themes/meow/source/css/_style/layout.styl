html
  // scrollbar for chrome
  *::-webkit-scrollbar
    width: 10px

  *::-webkit-scrollbar-thumb
    background-color: border-grey
    border-radius: 30px

  *::-webkit-scrollbar-thumb:hover
    background-color: #7f1d1d

  *::-webkit-scrollbar-thumb:active
    background-color: #111111

  *::-webkit-scrollbar-track
    background-color: code-light

  // scrollbar for firefox
  @-moz-document url-prefix()
    *
      scrollbar-color: #7f1d1d code-light
      scrollbar-width: thin
  
  scroll-behavior: smooth

:root
  --color-bg: #f7f3ea
  --color-surface: #fbf8f1
  --color-surface-dark: #111111
  --color-text: #111111
  --color-text-muted: #888888
  --color-border: #d8d8d4
  --color-link: #222222
  --color-link-hover: #555555
  --color-card-bg: #111111
  --color-card-text: #ffffff
  --color-card-muted: #a3a3a3
  --color-accent-subtle: #efefec
  --color-quote-bg: #f1f1f1
  --color-quote-border: #222222

body
  if hexo-config('background.type') == 1
    background: url($root-path + site-background-image)
  else if hexo-config('background.type') == 3
    background: site-background-gradient
  else
    background: site-background-color
  transition: background 0.5s ease-out
  -moz-transition: background 0.5s ease-out
  -webkit-transition: background 0.5s ease-out
  -o-transition: background 0.5s ease-out
  margin: 0
  padding: 0
  font-size: default-font-size
  font-family: default-font-family
  background-color: var(--color-bg)
  color: var(--color-text)
  position: relative

  if(! hexo-config('selectable'))
    -webkit-user-select: none /* Safari */
    -ms-user-select: none /* IE 10+ and Edge */
    -moz-user-select: none  /* Firefox */
    user-select: none /* Standard syntax */

  .main
    max-width: 1180px
    width: min(94%, 1180px)
    margin: 0 auto

    .main-content
      background-color: var(--color-surface)
      background-image: none
      border: 1px solid var(--color-border)
      border-radius: 18px
      box-shadow: 0 14px 34px rgba(0, 0, 0, 0.05)
      margin: 12px auto 48px
      padding: 34px 0 52px

// Keep the front-end typography consistent even where the theme provides
// component-specific font declarations. Font Awesome and code blocks retain
// their own font families so icons and syntax highlighting keep working.
body,
body :not(.fa-solid):not(.fa-regular):not(.fa-brands):not(.fa):not(code):not(pre):not(kbd):not(samp)
  font-family: default-font-family !important

body code,
body code *,
body pre,
body pre *,
body kbd,
body samp
  font-family: code-font !important

@media screen and (max-width: 768px)
  body
    font-size: default-font-size-smaller
