.page-container
  width: 85%
  margin: 0 auto

  a
    text-decoration: none
    color: text-black

.page-title
  color: #111111

  h1
    margin: 0.5em 0

  i
    margin-right: 5px

.archives-year
  margin: 20px 0

.archives-year-link
  font-size: article-title1-font-size
  font-weight: bold
  display: block
  width: 100%
  padding: 5px 0
  border-bottom: 2px solid border-grey
  vertical-align: middle

  i
    display: none

  &:hover
    color: #555555

    i
      display: inline
      margin-left: 5px


.archives-month
  margin: 20px 0

.archives-month-link
  margin: 10px 0
  display: block
  font-size: article-title3-font-size
  font-weight: bold

  i
    display: none

  &:hover
    color: #555555

    i
      display: inline
      margin-left: 5px

.archives-article-list
  display: flex
  flex-flow: row wrap
  align-items: center

.article-item
  width: 17.5%
  aspect-ratio: 1/1
  border: 1px solid #d8d8d4
  border-radius: 10px
  background: #ffffff
  box-shadow: 0 2px 8px rgba(31, 18, 53, 0.08)
  overflow: hidden
  margin-right: 2.3%
  margin-top: 10px
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease

  &:hover
    border-color: #a7a7a2
    box-shadow: 0 8px 18px rgba(31, 18, 53, 0.14)
    transform: translateY(-2px)

.article-item-card
  display: flex
  flex-flow: column nowrap
  width: 100%
  height: 100%
  font-size: info-font-size-normal

.article-item-title
  color: text-black
  font-size: article-title6-font-size
  font-weight: bold
  line-height: 1.4
  margin: 12px 12px 6px

.article-item-preview
  color: text-grey
  line-height: 1.55
  margin: 0 12px 10px
  word-break: break-all
  overflow: hidden
  text-align: justify

.article-item-date
  align-self: flex-end
  color: text-grey-light
  font-size: info-font-size-smaller
  margin: auto 12px 12px
  white-space: nowrap

@media screen and (max-width: 768px)
  .article-item
    width: 45%
    margin-right: 4%
  
  .article-item-title
    font-size: info-font-size-larger
    margin: 10px 10px 4px

  .article-item-preview
    margin: 0 10px 8px

  .article-item-date
    margin: auto 10px 10px
