.categories-list-container
  margin: 18px auto
  font-size: article-title5-font-size
  display: flex
  flex-flow: column wrap

.categories-item
  height: 2em
  display: flex
  align-items: center

  i
    margin-right 5px

  &:hover
    background: #efefec

.categories-item-count
  margin-left: 5px

.categories-list-container-helpers
  margin: 18px auto 8px
  font-size: article-title5-font-size

.category-list
  list-style: none
  padding-left: 0
  margin: 0

.category-list-item
  margin: 5px 0

.category-tree-row
  display: flex
  align-items: center
  gap: 8px
  min-height: 42px
  padding: 5px 10px
  border: 1px solid transparent
  border-radius: 10px
  transition: background-color 160ms ease, border-color 160ms ease, box-shadow 160ms ease

  &:hover
    background: #efefec
    border-color: #c9c9c4
    box-shadow: 0 1px 2px rgba(17, 17, 17, 0.08)

.category-tree-toggle,
.category-tree-toggle-spacer
  width: 24px
  height: 24px
  flex: 0 0 24px

.category-tree-toggle
  display: inline-flex
  align-items: center
  justify-content: center
  padding: 0
  border: 0
  border-radius: 7px
  background: transparent
  color: #444444
  cursor: pointer
  transition: background-color 160ms ease, transform 160ms ease

  &:hover
    background: #eeeeea

  .fa-chevron-right
    transition: transform 180ms ease

.category-list-item:not(.is-collapsed) > .category-tree-row .fa-chevron-right
  transform: rotate(90deg)

.category-tree-icon
  width: 18px
  color: #444444
  text-align: center

.category-list-item[data-category-depth='0'] > .category-tree-row
  font-size: article-title4-font-size
  font-weight: 800

.category-list-item[data-category-depth='1'] > .category-tree-row
  font-size: article-title5-font-size
  font-weight: 700

.category-list-item[data-category-depth]:not([data-category-depth='0']):not([data-category-depth='1']) > .category-tree-row
  font-size: default-font-size-smaller
  font-weight: 500

.category-list-link
  min-width: 0
  flex: 0 1 auto
  padding: 3px 4px
  border-radius: 6px
  color: #111111
  text-decoration: none

  &:hover
    color: #2f2f2f
    text-decoration: underline

.category-list-count
  display: inline-flex
  align-items: center
  justify-content: center
  min-width: 26px
  margin: 0
  padding: 2px 7px
  border-radius: 999px
  color: #555555
  background-color: #efefef
  border: 1px solid #d8d8d4
  text-align: center
  font-size: info-font-size-smaller
  line-height: 1.3

.category-list-child
  list-style: none
  max-height: 0
  margin: 0 0 0 18px
  padding-left: 18px
  overflow: hidden
  border-left: 1px solid #d0d0cc
  transition: max-height 240ms ease, margin 240ms ease, opacity 180ms ease
  opacity: 0

.category-list-item[data-category-tree-ready='true']:not(.is-collapsed) > .category-list-child
  max-height: 1200px
  margin-top: 5px
  margin-bottom: 5px
  opacity: 1

.category-list-item.is-collapsed > .category-list-child
  pointer-events: none

@media screen and (max-width: 768px)
  .category-tree-row
    gap: 6px
    min-height: 38px
    padding: 4px 6px

  .category-list-item[data-category-depth='0'] > .category-tree-row
    font-size: article-title5-font-size

  .category-list-child
    margin-left: 10px
    padding-left: 10px
