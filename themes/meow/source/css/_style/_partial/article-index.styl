.index-posts
  margin: 0 auto
  width: 85%

  .index-post-item
    margin-top: 14px
    padding: 20px
    border: 1px solid border-grey
    border-radius: 10px
    background: white
    box-shadow: 0 2px 8px rgba(31, 18, 53, 0.08)
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease

    &:hover
      border-color: rgba(249, 173, 8, 0.5)
      box-shadow: 0 8px 18px rgba(31, 18, 53, 0.14)
      transform: translateY(-2px)

    .post-title-index
      display: flex
      flex-flow: row nowrap
      align-items: baseline
      justify-content: space-between

      h1
        margin: 0

        a
          text-decoration: none
          color: text-black
          font-weight: bold

          &:hover
            color: orange-middle
          
          i
            margin-right: 5px
      
      .post-top
        padding: 3px 12px
        border: 1px orange-middle dashed
        border-radius: 15px
        text-align: center
        color: orange-middle

        p
          margin: 0
          white-space: nowrap
    
    .post-head-info
      display: flex
      flex-flow: row wrap
      align-items: center
      gap: 8px 14px
      margin-top: 10px
      font-size: info-font-size

      div
        margin-top: 0

      .post-published-at
        color: text-grey-light
        font-size: info-font-size-smaller
        white-space: nowrap

        i
          margin-right: 5px
    
    .read-more
      background-color: orange-low-saturation
      padding: 3px 10px
      border-radius: 20px
      display: inline-block
      text-align: center
      margin: 10px 0

      i
        margin-right: 3px
        color: white

      .read-more-link
        text-decoration: none
        color: white
        font-size: info-font-size

      &:hover
        background-color: yellow-normal
        box-shadow: 1.5px 1.5px 2px shadow-grey
    
    .post-tags
      font-size: info-font-size
      display: block
      white-space: nowrap
      overflow: hidden

.post-excerpt
  margin: 1em 0

.post-excerpt[excerpt-simplify=true]
  h1,h2,h3,h4,h5,h6
    font-size: default-font-size
    margin: 1em 0

@media screen and (max-width: 768px)
  .index-post-item
    padding: 16px

    h1
      font-size: article-title2-font-size

    .post-head-info
      align-items: flex-start
      flex-flow: column nowrap
      gap: 6px
  .post-excerpt[excerpt-simplify=true]
    h1,h2,h3,h4,h5,h6
      font-size: default-font-size-smaller
