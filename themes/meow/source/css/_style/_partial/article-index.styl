.index-posts
  margin: 0 auto
  width: min(88%, 980px)

  .index-post-item
    position: relative
    margin-top: 20px
    padding: 28px 30px
    border: 1px solid rgba(255, 255, 255, 0.08)
    border-radius: 16px
    background: var(--color-card-bg)
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.16)
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease

    &:hover
      border-color: rgba(255, 255, 255, 0.24)
      box-shadow: 0 16px 34px rgba(0, 0, 0, 0.24)
      transform: translateY(-3px)

    .post-title-index
      display: flex
      flex-flow: row nowrap
      align-items: baseline
      justify-content: space-between

      h1
        margin: 0

        a
          text-decoration: none
          color: var(--color-card-text)
          font-weight: bold

          &:hover
            color: #e5e5e5
          
          i
            margin-right: 5px
      
      .post-top
        position: absolute
        top: 0
        right: 0
        padding: 4px 10px
        border: 1px solid rgba(255, 255, 255, 0.25)
        border-radius: 999px
        background: rgba(255, 255, 255, 0.06)
        text-align: center
        color: #ffffff
        font-size: info-font-size-smaller

        p
          margin: 0
          white-space: nowrap
    
    .post-head-info
      display: flex
      flex-flow: row wrap
      align-items: center
      gap: 8px 14px
      margin-top: 10px
      font-size: info-font-size

      div
        margin-top: 0

      .post-published-at
        color: var(--color-card-muted)
        font-size: info-font-size-smaller
        white-space: nowrap

        i
          margin-right: 5px

      .post-categories .post-category,
      .post-tags .post-tag
        color: #b5b5b5

        &:hover
          color: #ffffff
    
    .read-more
      background-color: #ffffff
      padding: 7px 14px
      border-radius: 999px
      display: inline-block
      text-align: center
      margin: 10px 0

      i
        margin-right: 3px
        color: #111111

      .read-more-link
        text-decoration: none
        color: #111111
        font-size: info-font-size

      &:hover
        background-color: #e5e5e5
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.12)
        transform: translateY(-1px)

        i, .read-more-link
          color: #111111
    
    .post-tags
      font-size: info-font-size
      display: block
      white-space: nowrap
      overflow: hidden

.post-excerpt
  margin: 1em 0
  color: #e5e5e5

.post-excerpt[excerpt-simplify=true]
  h1,h2,h3,h4,h5,h6
    font-size: default-font-size
    margin: 1em 0

@media screen and (max-width: 768px)
  .index-post-item
    padding: 22px 20px

    h1
      font-size: article-title2-font-size

    .post-head-info
      align-items: flex-start
      flex-flow: column nowrap
      gap: 6px
  .post-excerpt[excerpt-simplify=true]
    h1,h2,h3,h4,h5,h6
      font-size: default-font-size-smaller
