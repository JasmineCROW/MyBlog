.index-posts
  margin: 0 auto
  width: min(88%, 980px)

  .index-post-item
    position: relative
    margin-top: 22px
    padding: 30px 32px
    border: 1px solid rgba(255, 255, 255, 0.12)
    border-radius: 18px
    background: var(--color-card-bg)
    box-shadow: 0 14px 32px rgba(17, 17, 17, 0.16)
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease

    &:hover
      border-color: rgba(255, 255, 255, 0.28)
      box-shadow: 0 20px 40px rgba(17, 17, 17, 0.24)
      transform: translateY(-4px)

    .post-title-index
      display: flex
      flex-flow: row nowrap
      align-items: baseline
      justify-content: space-between
      padding-right: 54px

      h1
        margin: 0
        font-size: clamp(1.42rem, 2vw, 2rem)
        line-height: 1.22

        a
          color: var(--color-card-text)
          font-weight: 900
          text-decoration: none

          &:hover
            color: #f2d6d6

          i
            display: none

      .post-top
        position: absolute
        top: 14px
        right: 14px
        padding: 3px 8px
        border: 1px solid rgba(242, 214, 214, 0.35)
        border-radius: 999px
        background: rgba(127, 29, 29, 0.22)
        color: #f6e8e8
        text-align: center
        font-size: 0.7rem
        line-height: 1.2

        p
          margin: 0
          white-space: nowrap

    .post-head-info
      display: flex
      flex-flow: row wrap
      align-items: center
      gap: 8px 14px
      margin-top: 12px
      font-size: info-font-size

      div
        margin-top: 0

      .post-published-at
        color: var(--color-card-muted)
        font-size: 0.82rem
        white-space: nowrap

        i
          margin-right: 5px

      .post-categories .post-category,
      .post-tags .post-tag
        color: #b7b7b7

        &:hover
          color: #f2d6d6

    .read-more
      display: inline-flex
      align-items: center
      gap: 7px
      margin: 12px 0 8px
      padding: 8px 15px
      border: 1px solid rgba(255, 255, 255, 0.18)
      border-radius: 999px
      background-color: #f7f3ea
      text-align: center
      transition: background-color 180ms ease, border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease

      i
        color: #111111
        transition: transform 180ms ease

      .read-more-link
        color: #111111
        font-size: 0.9rem
        font-weight: 800
        text-decoration: none

      &:hover
        border-color: rgba(255, 255, 255, 0.42)
        background-color: #ffffff
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.16)
        transform: translateY(-1px)

        i, .read-more-link
          color: #111111

        i
          transform: translateX(2px)

    .post-tags
      display: flex
      flex-flow: row wrap
      gap: 2px 8px
      overflow: hidden
      font-size: info-font-size

.post-excerpt
  margin: 1.05em 0
  color: #e8e8e4
  line-height: 1.86

.post-excerpt[excerpt-simplify=true]
  h1,h2,h3,h4,h5,h6
    margin: 1em 0
    font-size: default-font-size

.home-page
  .index-posts
    width: 100%

    .index-post-item:first-child
      margin-top: 0

@media screen and (max-width: 768px)
  .index-posts
    width: 100%

  .index-post-item
    padding: 22px 20px
    border-radius: 16px

    .post-title-index
      padding-right: 0

    h1
      font-size: article-title2-font-size

    .post-head-info
      align-items: flex-start
      flex-flow: column nowrap
      gap: 6px

  .post-excerpt[excerpt-simplify=true]
    h1,h2,h3,h4,h5,h6
      font-size: default-font-size-smaller

@media (prefers-reduced-motion: reduce)
  .index-posts .index-post-item,
  .index-posts .index-post-item .read-more,
  .index-posts .index-post-item .read-more i
    transition: none
