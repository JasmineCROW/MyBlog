.index-posts
  margin: 0 auto
  width: min(88%, 980px)

  .index-post-item
    position: relative
    margin-top: 20px
    padding: 28px 30px
    border: 1px solid #dededb
    border-radius: 16px
    background: #ffffff
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.045)
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease

    &:hover
      border-color: #a7a7a2
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.09)
      transform: translateY(-3px)

    .post-title-index
      display: flex
      flex-flow: row nowrap
      align-items: baseline
      justify-content: space-between

      h1
        margin: 0

        a
          text-decoration: none
          color: #161616
          font-weight: bold

          &:hover
            color: #7f1d1d
          
          i
            margin-right: 5px
      
      .post-top
        position: absolute
        top: 0
        right: 0
        padding: 4px 10px
        border: 1px solid #252525
        border-radius: 999px
        background: #ffffff
        text-align: center
        color: #252525
        font-size: info-font-size-smaller

        p
          margin: 0
          white-space: nowrap
    
    .post-head-info
      display: flex
      flex-flow: row wrap
      align-items: center
      gap: 8px 14px
      margin-top: 10px
      font-size: info-font-size

      div
        margin-top: 0

      .post-published-at
        color: #888888
        font-size: info-font-size-smaller
        white-space: nowrap

        i
          margin-right: 5px
    
    .read-more
      background-color: #1b1b1b
      padding: 7px 14px
      border-radius: 999px
      display: inline-block
      text-align: center
      margin: 10px 0

      i
        margin-right: 3px
        color: white

      .read-more-link
        text-decoration: none
        color: white
        font-size: info-font-size

      &:hover
        background-color: #ffffff
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.12)
        transform: translateY(-1px)

        i, .read-more-link
          color: #1b1b1b
    
    .post-tags
      font-size: info-font-size
      display: block
      white-space: nowrap
      overflow: hidden

.post-excerpt
  margin: 1em 0

.post-excerpt[excerpt-simplify=true]
  h1,h2,h3,h4,h5,h6
    font-size: default-font-size
    margin: 1em 0

@media screen and (max-width: 768px)
  .index-post-item
    padding: 22px 20px

    h1
      font-size: article-title2-font-size

    .post-head-info
      align-items: flex-start
      flex-flow: column nowrap
      gap: 6px
  .post-excerpt[excerpt-simplify=true]
    h1,h2,h3,h4,h5,h6
      font-size: default-font-size-smaller
