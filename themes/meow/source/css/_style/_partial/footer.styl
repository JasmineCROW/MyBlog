.footer-content
  max-width: max-page-width
  width: 90%
  margin: 20px auto 10px
  text-align: center
  font-size: footer-font-size
  color: #666666

  i
    margin: 0 5px

    &:first-child
      margin-left: 0
  
.copyright-info
  a
    text-decoration: none
    color: #444444

    &:hover
