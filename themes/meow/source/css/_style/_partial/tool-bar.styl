#tool-bar
  z-index: 5
  font-size: 20px
  line-height: 20px
  position: fixed
  right: 5px
  bottom: 5px
  animation: showup 1s

#tool-bar-main
  float: right
  padding: 8px
  background-color: #ffffff
  border: 1px solid #d8d8d4
  border-radius: 12px
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12)

  div
    width: 20px
    height: 20px
    margin-top: 6px

    &:first-child
      margin-top: 0
    
    &:hover
      color: #111111
      cursor: pointer

  #back-to-top
    display: none
    animation: showup 1s
    &:hover
      animation: bounce 1s ease-in-out infinite

#font-size-controls
  float: right
  margin-right: 2px
  padding: 8px
  background-color: #ffffff
  border: 1px solid #d8d8d4
  border-radius: 12px
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12)

  div
    width: 20px
    height: 20px
    margin-top: 6px
    color: #555555
    text-align: center

    &:first-child
      margin-top: 0
    
    &:hover
      color: #111111
      cursor: pointer
