#tool-bar
  z-index: 5
  font-size: 20px
  line-height: 20px
  position: fixed
  right: 16px
  bottom: 18px
  animation: showup 1s

#tool-bar-main
  display: flex
  flex-flow: column nowrap
  align-items: center
  gap: 8px
  padding: 10px 8px
  background-color: #ffffff
  border: 1px solid #d8d8d4
  border-radius: 999px
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12)
  color: #333333

  div
    width: 28px
    height: 28px
    display: flex
    align-items: center
    justify-content: center
    border-radius: 50%
    transition: background-color 160ms ease, color 160ms ease, transform 100ms ease

    &:hover
      background-color: #f0f0f0
      color: #111111
      cursor: pointer
      transform: translateY(-1px)

  #back-to-top
    display: none
    animation: showup 1s
    &:hover
      animation: bounce 1s ease-in-out infinite
