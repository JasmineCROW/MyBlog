header
  background-color: rgba(250, 250, 248, 0.92)
  position: sticky
  top: 0
  border-bottom: 1px solid #dededb
  box-shadow: none
  backdrop-filter: blur(14px)
  z-index: 6

.top-nav
  height: header-height
  max-width: max-page-width
  display: flex
  justify-content: space-between
  align-items: center
  margin: 0 auto
  width: 90%
  

.nav-info
  display: flex
  align-items: center
  font-weight: 1000

  div
    vertical-align: text-bottom
    display: inline-block

    #nav-icon
      width: 40px
      height: 40px
      margin: 0
      display: inline

      &:hover
        animation: fade 1.2s ease-in-out infinite

    #nav-title
      font-size: 26px
      font-weight: bold
      text-decoration: none
      color: #151515
      margin-left: 5px

      &:hover
        color: #555555

#top-menu-hidden
  display: none

.nav-ribbon
  display: flex
  align-items: center

#top-menu-btn
  display: none

.top-menu-expanded
  display: inline-block
  font-size: header-item-font-size
  font-weight: 800

  .top-menu-item
    display: inline-flex
    align-items: center
    gap: 6px
    padding: 4px 11px
    border: 1px solid #bdbdb9
    border-radius: 999px
    text-decoration: none
    color: #292929
    margin-right: 10px
    line-height: 1.2
    transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease

    i
      margin: 0

    &:hover
      color: #ffffff
      background-color: #1a1a1a
      border-color: #1a1a1a

.top-search
  display: inline-block
  cursor: pointer

  &:hover
    i
      animation: fade 1s infinite

  #top-search-btn
    padding: 5px 11px
    background-color: #ffffff
    border: 1px solid #bdbdb9
    border-radius: 70px
    font-size: info-font-size-larger

    // &:hover
    //   box-shadow: 1.5px 1.5px 2px shadow-grey

    span
      margin-left: 5px
      color: #555555

#theme-mode-switch
  display: inline-flex
  align-items: center
  gap: 6px
  margin-left: 9px
  padding: 5px 11px
  border: 1px solid #bdbdb9
  border-radius: 999px
  background: #ffffff
  color: #292929
  font-size: info-font-size
  cursor: pointer
  transition: background-color 160ms ease, color 160ms ease, transform 100ms ease

  &:hover
    background: #1a1a1a
    color: #ffffff

  &:active
    transform: translateY(1px)

@media screen and (max-width: 768px)
  #top-menu-btn
    display: inline-block
    width: 22px
    height: 22px
    margin-left: 15px
    font-size: info-font-size-larger
    cursor: pointer
  
  .top-menu-expanded
    display: none
  
  .top-search
    span
      display: none
    #top-search-btn
      border-radius: 50%
      padding: 2px 5px

  #theme-mode-switch
    margin-left: 10px
    padding: 4px 7px

    span
      display: none

  #top-menu-hidden
    z-index: 5
    position: fixed
    top: header-height
    width: 100%
    height: calc(100% - 50px)
    margin: 0 auto
    animation: show-menu 0.5s
    background-color: rgba(255, 255, 255, 0.5)
    backdrop-filter: blur(8px)
    -webkit-backdrop-filter: blur(8px)
    flex-direction: column
    font-weight: 1000

    &:not([menu-show])
      animation: disable-menu 0.5s

    .menu-hidden-content
      background-color: rgba(255, 255, 255, 0.5)
      box-shadow: 0 1px 1px rgba(0, 0, 0, 0.125)
      max-height: 80%
      overflow-y: auto

      .menu-hidden-nav
        width: 90%
        display: flex
        flex-flow: row wrap
        align-items: center
        justify-content: center
        margin: 0 auto
        padding: 20px 0

      .menu-hidden-item
        padding: 8px 35px
        margin: 8px 10px
        border: 1px solid #bdbdb9
        border-radius: 999px
        text-decoration: none
        line-height: 1.5em
        font-size: header-item-font-size-smaller
        color: #292929
        background-color: rgba(255, 255, 255, 0.85)
        opacity: 1
        flex: 1
        display: flex
        flex-flow: row nowrap
        align-items: center
        justify-content: center

        i
          margin-right: 5px

        &:hover
          color: #ffffff
          background-color: #1a1a1a
          border-color: #1a1a1a

          i
            animation: beat 1s infinite
    
    .menu-hidden-blank
      flex: 1
      -webkit-flex: 1
      -ms-flex: 1
