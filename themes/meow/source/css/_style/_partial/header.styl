header
  position: sticky
  top: 0
  z-index: 6
  border-bottom: 1px solid rgba(33, 30, 27, 0.12)
  background-color: rgba(247, 243, 234, 0.88)
  box-shadow: 0 1px 0 rgba(255, 255, 255, 0.65)
  backdrop-filter: blur(14px)

.top-nav
  display: flex
  align-items: center
  justify-content: space-between
  gap: 20px
  width: min(94%, 1180px)
  max-width: 1180px
  min-height: 58px
  margin: 0 auto

.nav-info
  display: flex
  align-items: center
  min-width: 0
  font-weight: 1000

  div
    display: inline-flex
    align-items: center
    vertical-align: text-bottom

    #nav-icon
      display: inline-block
      width: 34px
      height: 34px
      margin: 0
      filter: grayscale(1) contrast(1.08)

      &:hover
        animation: fade 1.2s ease-in-out infinite

    #nav-title
      margin-left: 9px
      color: #151515
      font-size: clamp(1.02rem, 2vw, 1.32rem)
      font-weight: 900
      line-height: 1
      text-decoration: none
      white-space: nowrap
      overflow: hidden
      text-overflow: ellipsis

      &:hover
        color: #7f1d1d

#top-menu-hidden
  display: none

.nav-ribbon
  display: flex
  align-items: center
  justify-content: flex-end
  gap: 8px
  min-width: 0

#top-menu-btn
  display: none

.top-menu-expanded
  display: inline-flex
  align-items: center
  gap: 4px
  min-width: 0
  font-size: 0.9rem
  font-weight: 800

  .top-menu-item
    display: inline-flex
    align-items: center
    gap: 6px
    padding: 7px 9px
    border: 1px solid transparent
    border-radius: 999px
    color: #292929
    line-height: 1.2
    text-decoration: none
    transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease

    i
      margin: 0
      color: #7f1d1d

    &:hover
      border-color: rgba(127, 29, 29, 0.18)
      background-color: rgba(127, 29, 29, 0.08)
      color: #7f1d1d
      transform: translateY(-1px)

.top-search
  display: inline-block
  cursor: pointer

  &:hover
    i
      color: #7f1d1d

  #top-search-btn
    display: inline-flex
    align-items: center
    gap: 6px
    padding: 7px 10px
    border: 1px solid rgba(33, 30, 27, 0.16)
    border-radius: 999px
    background-color: rgba(255, 255, 255, 0.58)
    color: #222222
    font-size: 0.9rem

    span
      color: #55514b

#theme-mode-switch
  display: inline-flex
  align-items: center
  gap: 6px
  padding: 7px 10px
  border: 1px solid rgba(33, 30, 27, 0.16)
  border-radius: 999px
  background: rgba(255, 255, 255, 0.58)
  color: #292929
  font-size: 0.9rem
  cursor: pointer
  transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease, transform 100ms ease

  &:hover
    border-color: rgba(127, 29, 29, 0.22)
    background: rgba(127, 29, 29, 0.08)
    color: #7f1d1d

  &:active
    transform: translateY(1px)

@media screen and (max-width: 940px)
  .top-nav
    width: 94%
    gap: 12px

  .top-menu-expanded
    max-width: 48vw
    overflow-x: auto
    scrollbar-width: none

    &::-webkit-scrollbar
      display: none

    .top-menu-item
      flex: 0 0 auto

@media screen and (max-width: 768px)
  #top-menu-btn
    display: inline-flex
    align-items: center
    justify-content: center
    width: 34px
    height: 34px
    border: 1px solid rgba(33, 30, 27, 0.16)
    border-radius: 999px
    color: #222222
    font-size: info-font-size-larger
    cursor: pointer

  .top-menu-expanded
    display: none

  .top-search
    span
      display: none

    #top-search-btn
      justify-content: center
      width: 34px
      height: 34px
      padding: 0

  #theme-mode-switch
    justify-content: center
    width: 34px
    height: 34px
    padding: 0

    span
      display: none

  #top-menu-hidden
    z-index: 5
    position: fixed
    top: 58px
    width: 100%
    height: calc(100% - 58px)
    margin: 0 auto
    animation: show-menu 0.35s
    background-color: rgba(247, 243, 234, 0.72)
    backdrop-filter: blur(10px)
    -webkit-backdrop-filter: blur(10px)
    flex-direction: column
    font-weight: 1000

    &:not([menu-show])
      animation: disable-menu 0.35s

    .menu-hidden-content
      max-height: 80%
      overflow-y: auto
      border-bottom: 1px solid rgba(33, 30, 27, 0.12)
      background-color: rgba(247, 243, 234, 0.92)
      box-shadow: 0 10px 24px rgba(17, 17, 17, 0.08)

      .menu-hidden-nav
        display: flex
        flex-flow: row wrap
        align-items: center
        justify-content: center
        width: 90%
        margin: 0 auto
        padding: 18px 0

      .menu-hidden-item
        display: flex
        flex: 1 1 140px
        flex-flow: row nowrap
        align-items: center
        justify-content: center
        margin: 7px
        padding: 9px 18px
        border: 1px solid rgba(33, 30, 27, 0.16)
        border-radius: 999px
        background-color: rgba(255, 255, 255, 0.72)
        color: #292929
        line-height: 1.5em
        font-size: header-item-font-size-smaller
        text-decoration: none

        i
          margin-right: 5px
          color: #7f1d1d

        &:hover
          border-color: rgba(127, 29, 29, 0.22)
          background-color: rgba(127, 29, 29, 0.08)
          color: #7f1d1d

    .menu-hidden-blank
      flex: 1
      -webkit-flex: 1
      -ms-flex: 1
