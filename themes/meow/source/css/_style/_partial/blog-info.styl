.blog-info
  box-sizing: border-box
  margin: 34px auto 22px
  padding: 26px 24px
  display: flex
  align-items: center
  flex-flow: column nowrap
  max-width: 1180px
  width: min(94%, 1180px)
  border: 1px solid #dfdfdb
  border-radius: 18px
  background: rgba(255, 255, 255, 0.7)
  box-shadow: 0 10px 28px rgba(0, 0, 0, 0.04)

#blog-pic
  width: 132px
  height: 132px
  margin: 0
  
.blog-title
  margin-top: 10px
  font-size: 36px
  font-weight: bold
  color: #171717
  text-shadow: none
  white-space: nowrap
  overflow: hidden
  animation: title-run 0.8s ease-in-out linear
  -webkit-animation: title-run 0.8s linear

  span
    margin: 0 12px
    font-weight: 1200
  
  i
    --fa-rotate-angle: 45deg

    &:first-child
      --fa-rotate-angle: 315deg
